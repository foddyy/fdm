<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Top Bar: Logo + Name | Language Switch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="12dp"
            android:background="#F5F5F5">

            <!-- Logo + Name (left) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_logo"
                    android:scaleType="fitCenter"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#333333" />
            </LinearLayout>

            <!-- Language Switch (right) -->
            <Button
                android:id="@+id/btnLangSwitch"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/lang_switch"
                android:textSize="14sp"
                android:textColor="#2196F3"
                android:backgroundTint="#E3F2FD"
                android:paddingStart="12dp"
                android:paddingEnd="12dp" />
        </LinearLayout>

        <!-- Main Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_horizontal">

            <!-- Status LED Indicator -->
            <View
                android:id="@+id/viewStatusCircle"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:background="@drawable/status_led_idle"
                android:layout_marginBottom="8dp" />

            <!-- Status Text -->
            <TextView
                android:id="@+id/tvStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_idle"
                android:textColor="#333333"
                android:textSize="16sp"
                android:layout_marginBottom="12dp" />

            <!-- Estimated Distance -->
            <TextView
                android:id="@+id/tvEstimatedDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/distance_info"
                android:textColor="#2196F3"
                android:textSize="28sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/threshold_info"
                android:textColor="#999999"
                android:textSize="12sp"
                android:layout_marginBottom="20dp" />

            <!-- Action Buttons -->
            <Button
                android:id="@+id/btnStartMonitor"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/btn_start_monitor"
                android:textSize="14sp"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnRecalibrate"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:text="@string/btn_recalibrate"
                android:textSize="14sp"
                android:backgroundTint="#FF6B35"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </LinearLayout>
</ScrollView>
