<?xml version="1.0" encoding="utf-8"?>
<!-- Landscape layout: left panel for controls, right panel for tip -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#FFFFFF">

    <!-- Left Panel: Controls & Status (scrollable) -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <!-- Top Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="16dp">

                <ImageView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:src="@drawable/ic_logo_transparent"
                    android:scaleType="fitCenter" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/app_name"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#333333"
                    android:layout_marginStart="8dp" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/btnLangSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="中文"
                    android:textSize="14sp"
                    android:textColor="#2196F3"
                    android:backgroundTint="#E3F2FD"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>

            <!-- LED Indicator (larger) -->
            <View
                android:id="@+id/viewStatusCircle"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="@drawable/status_led_idle"
                android:layout_marginBottom="12dp" />

            <!-- Status Text -->
            <TextView
                android:id="@+id/tvStatusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/status_idle"
                android:textColor="#333333"
                android:textSize="18sp"
                android:layout_marginBottom="16dp" />

            <!-- Distance Display -->
            <TextView
                android:id="@+id/tvEstimatedDistance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/distance_info"
                android:textColor="#2196F3"
                android:textSize="36sp"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/threshold_info"
                android:textColor="#999999"
                android:textSize="14sp"
                android:layout_marginBottom="24dp" />

            <!-- Buttons -->
            <Button
                android:id="@+id/btnStartMonitor"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_start_monitor"
                android:textSize="16sp"
                android:backgroundTint="#2196F3"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btnRecalibrate"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="@string/btn_recalibrate"
                android:textSize="16sp"
                android:backgroundTint="#FF6B35"
                android:textColor="#FFFFFF"
                android:layout_marginBottom="12dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Right Panel: Tip QR Code -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="打赏作者"
            android:textColor="#999999"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <ImageView
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:src="@drawable/ic_tip_qr"
            android:contentDescription="打赏码" />
    </LinearLayout>

</LinearLayout>
